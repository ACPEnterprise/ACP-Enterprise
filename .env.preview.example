# Copy this file to .env.preview on the preview server. Never commit .env.preview.
# Values containing JSON must remain valid JSON on one line.

COMPOSE_PROJECT_NAME=acp-enterprise-preview
PREVIEW_HTTP_PORT=8080

APP_NAME=ACP Enterprise
APP_VERSION=0.1.0
BUSINESS_TIMEZONE=America/New_York
LOG_LEVEL=INFO

# Use a preview-only database name and credentials. The password in DATABASE_URL
# must be URL-encoded if it contains reserved URL characters.
POSTGRES_DB=acp_enterprise_preview
POSTGRES_USER=acp_enterprise
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PREVIEW_DATABASE_PASSWORD
DATABASE_URL=postgresql+asyncpg://acp_enterprise:REPLACE_WITH_URL_ENCODED_PREVIEW_DATABASE_PASSWORD@postgres:5432/acp_enterprise_preview
REDIS_URL=redis://redis:6379/0

# Exact browser origins and host names only. Wildcards are rejected in preview.
CORS_ALLOWED_ORIGINS=["https://preview.allcountyhomeservices.com"]
ALLOWED_HOSTS=["preview.allcountyhomeservices.com","backend","localhost","127.0.0.1"]

# The fixed Compose preview network is the only trusted application proxy network.
TRUST_FORWARDED_HEADERS=true
TRUSTED_PROXY_CIDRS=["172.30.0.0/24"]

# Generate independent preview-only values. Each secret must contain at least
# 32 random characters. ACCESS_TOKEN_KEYS is a JSON object keyed by signing-key ID.
ACCESS_TOKEN_ACTIVE_KID=preview-2026-01
ACCESS_TOKEN_KEYS={"preview-2026-01":"REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"}
ACCESS_TOKEN_ALGORITHM=HS256
ACCESS_TOKEN_ISSUER=acp-enterprise-preview
ACCESS_TOKEN_AUDIENCE=acp-enterprise-preview-api
SECURITY_TOKEN_HMAC_KEY=REPLACE_WITH_A_DIFFERENT_32_CHARACTER_RANDOM_SECRET

# Secure defaults required by preview configuration validation.
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
